{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trip Viewer",
  "version": "../package.json",
  "identifier": "com.tripviewer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trip Viewer",
        "width": 1280,
        "height": 760,
        "minWidth": 720,
        "minHeight": 600,
        "center": true,
        "visible": false,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.comodoca.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQjkzMUNDMUQzOTc2REIKUldUYmRqa2R6REc1LzFTRmZKMEtFOXRSWFJDYVhrMkNLdTZUVlkvV0V0TlVZSG5hSEdDRTRXUEkK",
      "endpoints": [
        "https://github.com/chrisl8/trip-viewer/releases/latest/download/latest.json"
      ]
    }
  }
}
